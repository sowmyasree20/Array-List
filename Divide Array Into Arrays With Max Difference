class Solution {
    public int[][] divideArray(int[] nums, int k) {
        Arrays.sort(nums);
        int n=nums.length;
        int[][] r=new int[n/3][3];
        int s=0;
        for(int i=0;i<n;i+=3){
            if(nums[i+2]-nums[i]>k){
                return new int[0][0];
            }
            r[s][0]=nums[i];
            r[s][1]=nums[i+1];
            r[s][2]=nums[i+2];
            s++;
        }
        return r;
    }
}
